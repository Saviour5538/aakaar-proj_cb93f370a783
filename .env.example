# Backend database connection string
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>

# Secret key for signing JWT tokens
JWT_SECRET=<random secret>

# Backend server port
PORT=8000

# Frontend API URL for connecting to the backend
VITE_API_URL=http://localhost:8000

# OpenAI API key for LLM integration
OPENAI_API_KEY=<your OpenAI API key>

# Anthropic API key for LLM integration
ANTHROPIC_API_KEY=<your Anthropic API key>

# Pinecone API key for vector database integration
PINECONE_API_KEY=<your Pinecone API key>

# PostgreSQL URL for pgvector vector database
POSTGRES_URL=postgresql://<username>:<password>@<host>:<port>/<database>